{
  "name": "vue-audit-v4-node-tools",
  "version": "1.0.0",
  "description": "Node.js static analysis tools for the V4 Code Audit Pipeline",
  "private": true,
  "scripts": {
    "lint": "eslint . --ext .vue,.js,.ts --format json",
    "style": "stylelint \"**/*.{vue,css,scss}\" --formatter json",
    "spell": "cspell \"**/*.{vue,js,ts}\" --reporter json",
    "depcruise": "depcruise src --output-type json",
    "duplication": "jscpd . --reporters json --ignore \"**/node_modules/**,**/dist/**\""
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/eslint-parser": "^7.24.1",
    "@babel/plugin-syntax-import-assertions": "^7.28.6",
    "@babel/preset-env": "^7.29.2",
    "cspell": "^8.8.4",
    "dependency-cruiser": "^17.3.10",
    "eslint": "^8.57.0",
    "eslint-plugin-vue": "^9.26.0",
    "eslint-plugin-vuejs-accessibility": "^2.5.0",
    "jscpd": "^4.0.5",
    "postcss-html": "^1.6.0",
    "stylelint": "^16.3.1",
    "stylelint-config-standard": "^40.0.0",
    "vue-eslint-parser": "^9.4.3",
    "vue-mess-detector": "^0.68.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
