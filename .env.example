# ─────────────────────────────────────────────────────────────
# Code Audit Librarian — Environment Secrets (EXAMPLE)
# ─────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your real values.
# NEVER commit the actual .env file.

# OpenWebUI / Ollama-compatible API endpoint
OPENWEBUI_BASE_URL=http://<your-openwebui-host>:<port>

# API key for OpenWebUI (use "ollama" if running plain Ollama)
OPENWEBUI_API_KEY=sk-your-key-here

# Model name to use for all LLM calls
LLM_MODEL=gemma3:latest
